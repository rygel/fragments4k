<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search: {{ query }} - {{ siteTitle }}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            line-height: 1.6;
        }
        h1, h2 {
            color: #333;
        }
        .nav {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #eee;
        }
        .nav a {
            margin-right: 15px;
            color: #0066cc;
            text-decoration: none;
        }
        .nav a:hover {
            text-decoration: underline;
        }
        .search-box {
            margin-bottom: 30px;
            padding: 20px;
            background: #f9f9f9;
            border-radius: 5px;
        }
        .search-box input {
            width: 100%;
            padding: 10px;
            font-size: 16px;
            border: 1px solid #ddd;
            border-radius: 5px;
            box-sizing: border-box;
        }
        .search-box button {
            margin-top: 10px;
            padding: 10px 20px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }
        .search-box button:hover {
            background: #0056b3;
        }
        .results-count {
            color: #666;
            margin-bottom: 20px;
        }
        .result-item {
            margin-bottom: 30px;
            padding: 20px;
            background: #f9f9f9;
            border-radius: 5px;
            border-left: 4px solid #007bff;
        }
        .result-title {
            font-size: 1.3em;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .result-title a {
            color: #0066cc;
            text-decoration: none;
        }
        .result-title a:hover {
            text-decoration: underline;
        }
        .result-preview {
            color: #555;
            margin-bottom: 10px;
        }
        .result-meta {
            color: #777;
            font-size: 0.9em;
        }
        .tag {
            display: inline-block;
            background: #e9ecef;
            padding: 2px 8px;
            border-radius: 3px;
            margin-right: 5px;
            font-size: 0.85em;
        }
        .no-results {
            padding: 40px;
            text-align: center;
            color: #666;
            background: #f9f9f9;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <nav class="nav">
        {% for item in viewModel.navigationMenu %}
        <a href="{{ item.url }}"{% if item.cssClass %} class="{{ item.cssClass }}"{% endif %}>{{ item.label }}</a>
        {% endfor %}
    </nav>

    <h1>Search Results for "{{ query }}"</h1>

    <div class="search-box">
        <form action="{{ searchForm.actionUrl }}" method="{{ searchForm.method }}">
            <input type="text" name="{{ searchForm.paramName }}" placeholder="{{ searchForm.placeholderText }}" value="{{ query }}">
            <button type="submit">{{ searchForm.buttonText }}</button>
        </form>
    </div>

    {% if results is not empty %}
    <p class="results-count">Found {{ results|length }} result{% if results|length != 1 %}s{% endif %}</p>

    {% for result in results %}
    <article class="result-item">
        <h2 class="result-title">
            {% if result.template == 'blog_post' %}
            <a href="/blog/{{ result.date[0] }}/{{ "%02d"|format(result.date[1]) }}/{{ result.slug }}">{{ result.title }}</a>
            {% else %}
            <a href="/page/{{ result.slug }}">{{ result.title }}</a>
            {% endif %}
        </h2>
        <p class="result-preview">{{ result.preview }}</p>
        <p class="result-meta">
            {% if result.date %}
            {{ result.formattedDate }}
            {% endif %}
            {% if result.tags is not empty %}
            • Tags: {% for tag in result.tags %}<span class="tag">{{ tag }}</span>{% if not loop.last %}, {% endif %}{% endfor %}
            {% endif %}
        </p>
    </article>
    {% endfor %}
    {% else %}
    <div class="no-results">
        <h2>No results found</h2>
        <p>We couldn't find any articles matching "{{ query }}".</p>
        <p>Try:</p>
        <ul>
            <li>Checking your spelling</li>
            <li>Using different keywords</li>
            <li>Searching for a less specific term</li>
        </ul>
    </div>
    {% endif %}

    <footer>
        <p>&copy; {{ footer.year }} {{ footer.copyrightText }} {{ footer.poweredByText }}</p>
    </footer>
</body>
</html>
