<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if month %}{{ month }}/{% endif %}{{ year }} Archive - Fragments4k Demo</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            line-height: 1.6;
        }
        h1, h2 {
            color: #333;
        }
        .nav {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #eee;
        }
        .nav a {
            margin-right: 15px;
            color: #0066cc;
            text-decoration: none;
        }
        .nav a:hover {
            text-decoration: underline;
        }
        .archive-header {
            margin-bottom: 30px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid #007bff;
        }
        .archive-header h1 {
            margin: 0 0 10px 0;
        }
        .archive-count {
            color: #666;
            margin-bottom: 20px;
            font-style: italic;
        }
        .archive-breadcrumbs {
            margin-bottom: 20px;
            padding: 10px;
            background: #f9f9f9;
            border-radius: 5px;
        }
        .archive-breadcrumbs a {
            color: #0066cc;
            text-decoration: none;
            margin: 0 5px;
        }
        .archive-breadcrumbs a.active {
            color: #333;
            font-weight: bold;
        }
        .archive-breadcrumbs a:hover {
            text-decoration: underline;
        }
        .archive-years, .archive-months {
            margin-bottom: 30px;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 5px;
        }
        .archive-years h3, .archive-months h3 {
            margin-top: 0;
            margin-bottom: 10px;
            color: #333;
        }
        .archive-year-list, .archive-month-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .archive-year-list li, .archive-month-list li {
            display: inline;
        }
        .archive-year-list a, .archive-month-list a {
            color: #0066cc;
            text-decoration: none;
            padding: 5px 10px;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 3px;
        }
        .archive-year-list a:hover, .archive-month-list a:hover {
            background: #007bff;
            color: white;
            border-color: #007bff;
        }
        .archive-year-list a.active, .archive-month-list a.active {
            background: #007bff;
            color: white;
            border-color: #007bff;
            font-weight: bold;
        }
        .archive-item {
            margin-bottom: 20px;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 5px;
            border-left: 4px solid #007bff;
        }
        .archive-title {
            font-size: 1.2em;
            font-weight: bold;
            margin-bottom: 5px;
        }
        .archive-title a {
            color: #0066cc;
            text-decoration: none;
        }
        .archive-title a:hover {
            text-decoration: underline;
        }
        .archive-date {
            color: #666;
            font-size: 0.9em;
            margin-bottom: 5px;
        }
        .reading-time {
            color: #28a745;
            font-weight: bold;
        }
        .archive-preview {
            color: #555;
        }
        .no-posts {
            text-align: center;
            padding: 40px;
            background: #f8f9fa;
            border-radius: 8px;
            color: #666;
        }
    </style>
</head>
<body>
    <nav class="nav">
        {% for item in viewModel.navigationMenu %}
        <a href="{{ item.url }}"{% if item.cssClass %} class="{{ item.cssClass }}"{% endif %}>{{ item.label }}</a>
        {% endfor %}
    </nav>

    <div class="archive-header">
        <h1>Archive{% if month %}: {{ month }}/{% endif %} {{ year }}</h1>

    {% if archiveBreadcrumbs %}
    <div class="archive-breadcrumbs">
        {% for crumb in archiveBreadcrumbs %}
        <a href="{{ crumb.url }}"{% if crumb.isActive %} class="active"{% endif %}>{{ crumb.label }}</a>{% if not loop.last %} &rarr; {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    {% if archiveYearLinks %}
    <div class="archive-years">
        <h3>Years</h3>
        <ul class="archive-year-list">
            {% for yearLink in archiveYearLinks %}
            <li><a href="{{ yearLink.url }}"{% if yearLink.isActive %} class="active"{% endif %}>{{ yearLink.label }}</a></li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    {% if archiveMonthLinks %}
    <div class="archive-months">
        <h3>Months</h3>
        <ul class="archive-month-list">
            {% for monthLink in archiveMonthLinks %}
            <li><a href="{{ monthLink.url }}"{% if monthLink.isActive %} class="active"{% endif %}>{{ monthLink.label }}</a></li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}
        <p class="archive-count">{% if fragments %}{{ fragments|length }} post{% if fragments|length != 1 %}s{% endif %}{% else %}No posts{% endif %} in this period</p>
    </div>

    {% if fragments %}
    {% for fragment in fragments %}
    <article class="archive-item">
        <h2 class="archive-title">
            <a href="/blog/{{ fragment.year }}/{{ "%02d"|format(fragment.month) }}/{{ fragment.slug }}">{{ fragment.title }}</a>
        </h2>
        <p class="archive-date">
            {{ fragment.formattedDate }}
            <span class="reading-time">&bull; {{ fragment.readingTime.text }}</span>
        </p>
        <p class="archive-preview">{{ fragment.preview }}</p>
    </article>
    {% endfor %}
    {% else %}
    <div class="no-posts">
        <h2>No posts found</h2>
        <p>There are no blog posts for this time period.</p>
    </div>
    {% endif %}

    <footer>
        <p><a href="/blog">&larr; Back to blog</a></p>
        <p>&copy; {{ footer.year }} {{ footer.copyrightText }} {{ footer.poweredByText }}</p>
    </footer>
</body>
</html>
