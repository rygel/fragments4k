<?xml version="1.0" encoding="UTF-8"?>
<ruleset comparisonMethod="maven"
         xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0
                             https://mojo.codehaus.org/versions-maven-plugin/xsd/rule-2.0.0.xsd">
    <rules>
        <!-- Kotlin is pinned: do not update due to CodeQL compatibility requirements -->
        <rule groupId="org.jetbrains.kotlin" comparisonMethod="maven">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <!-- Skip pre-release versions for all dependencies -->
        <rule comparisonMethod="maven">
            <ignoreVersions>
                <ignoreVersion type="regex">.*-alpha.*</ignoreVersion>
                <ignoreVersion type="regex">.*-beta.*</ignoreVersion>
                <ignoreVersion type="regex">.*-M\d+.*</ignoreVersion>
                <ignoreVersion type="regex">.*-RC\d+.*</ignoreVersion>
                <ignoreVersion type="regex">.*-rc\d+.*</ignoreVersion>
                <ignoreVersion type="regex">.*\.Beta.*</ignoreVersion>
                <ignoreVersion type="regex">.*\.Alpha.*</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>
</ruleset>
