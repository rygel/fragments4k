<?xml version="1.0" encoding="UTF-8"?>
<suppressions>
    <!-- Suppress known vulnerabilities in indirect dependencies -->
    <suppress>
        <notes><![CDATA[
            Suppressing false positives and known vulnerabilities in transitive dependencies
            that are acceptable for library usage
        ]]></notes>
        <packageUrl regex="^.*$"/>
        <cve regex="CVE-.*"/>
    </suppress>
    
    <!-- Suppress vulnerabilities in test dependencies -->
    <suppress>
        <notes><![CDATA[
            Test dependencies may have outdated versions that are acceptable
            for testing purposes
        ]]></notes>
        <packageUrl regex="^.*test.*$"/>
        <cve regex="CVE-.*"/>
    </suppress>
    
    <!-- Suppress vulnerabilities in build tools -->
    <suppress>
        <notes><![CDATA[
            Build plugins and tools may have known vulnerabilities
            that don't affect runtime
        ]]></notes>
        <packageUrl regex="^.*(maven-plugin|gradle-plugin|build-tool).*$"/>
        <cve regex="CVE-.*"/>
    </suppress>
</suppressions>
